{
  "name": "it-asset-mngt",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9.9.1",
    "@sap/jobs-client": "^1.9.0",
    "@sap/xssec": "^4",
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-analytical": "cds watch --open analytical/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employee-dashboard": "cds watch --open employeedashboard/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-it-dashboard": "cds watch --open itdashboard/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employee_portal": "cds watch --open employeeportal/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy it-asset-mngt --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-it-agent-dashboard": "cds watch --open itagentdashboard/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "server": {
      "index": true
    },
    "requires": {
      "auth": {
        "kind": "dummy",
        "users": {
          "alice": {
            "password": "alice",
            "roles": [
              "Asset.Read",
              "Ticket.Read",
              "Ticket.Write"
            ]
          },
          "bob": {
            "password": "bob",
            "roles": [
              "Asset.Read",
              "Ticket.Manage"
            ]
          },
          "carol": {
            "password": "carol",
            "roles": [
              "Asset.Read",
              "Asset.Manage",
              "Ticket.Manage"
            ]
          },
          "admin": {
            "password": "admin",
            "roles": [
              "Admin.All"
            ]
          }
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/analytical",
    "app/employee-dashboard",
    "app/it-dashboard",
    "app/employee_portal",
    "app/employee_portal",
    "app/analytical",
    "app/it-agent-dashboard"
  ]
}
